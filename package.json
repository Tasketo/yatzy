{
  "name": "yatzy",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "tsc --noEmit && eslint .",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "playwright:install": "playwright install --with-deps chromium",
    "lint:fix": "npm run lint -- --fix",
    "format:fix": "prettier --write .",
    "format": "prettier --check .",
    "coverage:merge": "nyc merge coverage/playwright coverage/coverage-final.json",
    "coverage:report": "nyc report --reporter=html --report-dir=coverage/html --temp-dir=coverage",
    "coverage:html": "npm run coverage:merge && npm run coverage:report"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.35.0",
    "@emotion/react": "^11.14.0",
    "i18next": "^26.1.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.6",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "istanbul-reports": "^3.2.0",
    "nyc": "^18.0.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.14",
    "vite-plugin-istanbul": "^8.0.0"
  },
  "overrides": {
    "uuid": "^14.0.0"
  }
}
