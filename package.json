{
  "name": "yatzy",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "tsc --noEmit && eslint .",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "playwright:install": "playwright install --with-deps chromium",
    "lint:fix": "npm run lint -- --fix",
    "format:fix": "prettier --write .",
    "format": "prettier --check .",
    "coverage:merge": "nyc merge coverage/playwright coverage/coverage-final.json",
    "coverage:report": "nyc report --reporter=html --report-dir=coverage/html --temp-dir=coverage",
    "coverage:html": "npm run coverage:merge && npm run coverage:report"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.36.0",
    "@emotion/react": "^11.14.0",
    "i18next": "^26.3.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.10",
    "react-icons": "^5.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "istanbul-reports": "^3.2.0",
    "nyc": "^18.0.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vite-plugin-istanbul": "^9.0.1"
  },
  "overrides": {
    "uuid": "^14.0.0"
  }
}
